#!/bin/bash
# + -- --=[Sn1per Community Edition by @xer0dayz
# + -- --=[https://sn1persecurity.com

INSTALL_DIR="$(dirname "$(readlink -f "$0")")"
LOOT_DIR="$INSTALL_DIR/loot/$TARGET"
SNIPER_PRO="$INSTALL_DIR/pro.sh"

source "$INSTALL_DIR/lib/bootstrap.sh"
source "$INSTALL_DIR/lib/logging.sh"
source "$INSTALL_DIR/lib/nmap-parser.sh"
source "$INSTALL_DIR/lib/mode-skeleton.sh"
source "$INSTALL_DIR/lib/workspace.sh"
source "$INSTALL_DIR/lib/update.sh"
source "$INSTALL_DIR/lib/cli.sh"
source "$INSTALL_DIR/lib/reports.sh"

sniper_require_root

service postgresql start 2>/dev/null

sniper_load_config "$INSTALL_DIR/conf" "$INSTALL_DIR/sniper.conf"
[[ ! -f /root/.sniper.conf ]] && cp "$INSTALL_DIR/sniper.conf" /root/.sniper.conf 2>/dev/null

DISTRO=$(cat /etc/*-release 2>/dev/null | grep DISTRIB_ID= | cut -d'=' -f2)

sniper_parse_args "$@"

[[ -n "$TARGET" && -z "$WORKSPACE" ]] && WORKSPACE="$TARGET"
[[ -n "$WORKSPACE" ]] && WORKSPACE_DIR="$INSTALL_DIR/loot/workspace/$WORKSPACE" && LOOT_DIR="$WORKSPACE_DIR"

if [[ -z "$TARGET" && -z "$WORKSPACE" ]]; then
  logo
  echo "You need to specify a target or workspace to use. Type sniper --help for command usage."
  exit 1
fi

cd "$INSTALL_DIR"

SCAN_TYPE=$(sniper_detect_scan_type)

sniper_init_workspace "$LOOT_DIR" "$TARGET" "$WORKSPACE_DIR" "$AUTO_BRUTE" "$FULLNMAPSCAN" "$OSINT" "$RECON"

if [[ ! -f /tmp/update-check.txt ]]; then
  sniper_check_online
fi
if [[ ! -f /tmp/update-check.txt ]]; then
  sniper_check_update
fi

if [[ "$REIMPORT" == "1" && -n "$WORKSPACE_DIR" ]]; then
  report_run "$LOOT_DIR" "$WORKSPACE"
  exit
fi

if [[ "$REIMPORT_ALL" == "1" && -n "$WORKSPACE_DIR" ]]; then
  touch "$WORKSPACE_DIR/domains/targets.txt" "$WORKSPACE_DIR/domains/targets-all-sorted.txt" "$WORKSPACE_DIR/domains/domains-all-sorted.txt"
  cat "$WORKSPACE_DIR/domains/targets.txt" "$WORKSPACE_DIR/domains/targets-all-sorted.txt" "$WORKSPACE_DIR/domains/domains-all-sorted.txt" | sort -u > "$WORKSPACE_DIR/scans/updated.txt"
  rm -f "$WORKSPACE_DIR/nmap/openports-unsorted.txt" "$WORKSPACE_DIR/nmap/openports-sorted.txt" "$WORKSPACE_DIR/reports/host-table-report.csv" 2>/dev/null
  report_run "$LOOT_DIR" "$WORKSPACE"
  exit
fi

if [[ "$RELOAD" == "1" && -n "$WORKSPACE_DIR" ]]; then
  ${BROWSER:-firefox} "$WORKSPACE_DIR/sniper-report.html" 2>/dev/null >/dev/null &
  exit
fi

if grep -q BlackArch /etc/issue 2>/dev/null; then
  DISTRO='blackarch'
  echo "Detected BlackArch GNU/Linux"
  INSTALL_DIR=$(pwd)
  echo "Setting current path to $INSTALL_DIR"
fi

source "$INSTALL_DIR/modes/discover.sh"
source "$INSTALL_DIR/modes/flyover.sh"
source "$INSTALL_DIR/modes/vulnscan.sh"
source "$INSTALL_DIR/modes/fullportonly.sh"
source "$INSTALL_DIR/modes/web.sh"
source "$INSTALL_DIR/modes/webporthttp.sh"
source "$INSTALL_DIR/modes/webporthttps.sh"
source "$INSTALL_DIR/modes/webscan.sh"
source "$INSTALL_DIR/modes/massweb.sh"
source "$INSTALL_DIR/modes/masswebscan.sh"
source "$INSTALL_DIR/modes/massvulnscan.sh"
source "$INSTALL_DIR/modes/massportscan.sh"
source "$INSTALL_DIR/modes/stealth.sh"
source "$INSTALL_DIR/modes/airstrike.sh"
source "$INSTALL_DIR/modes/nuke.sh"
source "$INSTALL_DIR/modes/normal.sh"

rm -f /tmp/update-check.txt 2>/dev/null
exit 0
